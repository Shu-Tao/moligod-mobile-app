# ====== Moligod 应用签名配置示例 ======
# 使用步骤:
#   1. 复制本文件为 keystore.properties (放在 android/ 目录下)
#   2. 把你的签名密钥文件 (.keystore 或 .jks) 放到 android/ 目录
#   3. 填入以下 4 项信息
#   4. 构建: .\gradlew.bat assembleRelease
# =======================================

# 密钥库文件路径 (相对 android/ 目录, 或绝对路径)
storeFile=moligod-release.keystore

# 密钥库密码
storePassword=your-store-password

# 密钥别名
keyAlias=moligod

# 密钥密码
keyPassword=your-key-password
